class Solution(object):
    def isValid(self, s):
         mapping = {"}":"{",")":"(","]":"["}
         stack=[]
         for symbol in s:
            if symbol in ("(","{","["):
                stack.append(symbol)
            else:
                if not stack:
                     return False

               
                if stack[-1] == mapping[symbol]:
                    stack.pop()
                else:
                   return False
         return len(stack) ==0
