class Solution(object):
    def maxArea(self, height):
        left=0
        right=len(height)-1
        maxi=0
        while left<right:
            width = right-left
            mini=min(height[left],height[right])
            water = width*mini
            maxi=max(maxi,water)
            if height[left]<height[right]:
                left+=1
            else:
                right-=1
        return maxi
